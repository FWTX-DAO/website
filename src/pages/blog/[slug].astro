---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";

// Generate a new path for every collection entry
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// Get the entry directly from the prop on render
const { entry } = Astro.props;
const { Content } = await entry.render();

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: entry.data.title,
  description: entry.data.snippet,
  author: {
    "@type": "Person",
    name: entry.data.author,
  },
  datePublished: entry.data.publishDate.toISOString(),
  publisher: {
    "@type": "Organization",
    name: "FWTX DAO",
    logo: {
      "@type": "ImageObject",
      url: "https://fwtx.city/logo.svg",
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": `https://fwtx.city/blog/${entry.slug}`,
  },
  image: entry.data.image?.src ? `https://fwtx.city${entry.data.image.src}` : undefined,
  keywords: entry.data.tags?.join(", "),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://fwtx.city",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: "https://fwtx.city/blog",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: entry.data.title,
      item: `https://fwtx.city/blog/${entry.slug}`,
    },
  ],
};
---

<Layout
  title={entry.data.title}
  description={entry.data.snippet}
  image={entry.data.image?.src}
  type="article"
  publishDate={entry.data.publishDate.toISOString()}
  author={entry.data.author}
  tags={entry.data.tags}>
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Container>
    <div class="mx-auto max-w-3xl mt-14">
      <span class="text-frontier-amber uppercase tracking-wider text-sm font-medium">
        {entry.data.category}
      </span>
      <h1
        class="font-display text-5xl lg:text-6xl font-bold tracking-tight mt-1 leading-tight text-white">
        {entry.data.title}
      </h1>
      <div class="flex gap-2 mt-3 items-center flex-wrap md:flex-nowrap">
        <span class="text-slate-400">
          {entry.data.author}
        </span>
        <span class="text-slate-400">&bull;</span>
        <time
          class="text-slate-400"
          datetime={entry.data.publishDate.toISOString()}>
          {new Intl.DateTimeFormat('en-US', { dateStyle: 'medium' }).format(entry.data.publishDate)}
        </time>
        <span class="text-slate-400 hidden md:block">&bull;</span>
        <div class="w-full md:w-auto flex flex-wrap gap-3">
          {
            entry.data.tags.map((tag) => (
              <span class="text-sm text-slate-400">#{tag}</span>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mx-auto prose prose-lg prose-invert mt-6 max-w-3xl">
      <Content />
    </div>
    <div class="text-center mt-8">
      <a
        href="/blog"
        class="bg-transparent text-frontier-amber font-semibold border-2 border-frontier-amber/50 hover:border-frontier-amber hover:bg-frontier-amber/10 hover:shadow-glow-amber px-5 py-3 rounded-md transition-all duration-300 focus-visible:ring-2 focus-visible:ring-frontier-amber/50 focus-visible:ring-offset-2 focus-visible:ring-offset-cyber-dark inline-block"
        >&larr; Back to Blog</a
      >
    </div>
  </Container>
</Layout>
