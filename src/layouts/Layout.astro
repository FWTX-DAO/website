---
import { SEO } from "astro-seo";
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import NeuralBackground from "@components/ui/flow-field-background";
import "@fontsource-variable/plus-jakarta-sans/index.css";
import "@fontsource/teko/400.css";
import "@fontsource/teko/500.css";
import "@fontsource/teko/600.css";
import "@fontsource/teko/700.css";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  publishDate?: string;
  author?: string;
  tags?: string[];
  type?: "website" | "article";
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const { title, description, image, noindex, publishDate, author, tags, type = "website" } = Astro.props;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": ["Organization", "NGO"],
  name: "FWTX DAO",
  legalName: "Fort Worth DAO LCA",
  url: "https://fwtx.city",
  logo: "https://fwtx.city/logo.svg",
  description: "Fort Worth Municipal DAO - Web3 civic innovation, digital sovereignty, and decentralized governance community in Fort Worth, Texas.",
  foundingDate: "2023-12-19",
  areaServed: {
    "@type": "City",
    name: "Fort Worth",
    containedInPlace: {
      "@type": "State",
      name: "Texas",
    },
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Fort Worth",
    addressRegion: "TX",
    addressCountry: "US",
  },
  contactPoint: {
    "@type": "ContactPoint",
    email: "community@fwtx.city",
    contactType: "community",
    url: "https://fwtx.city/contact",
  },
  sameAs: [
    "https://twitter.com/FWTX_DAO",
    "https://github.com/FWTX-DAO",
    "https://www.linkedin.com/company/fwtx-dao",
    "https://www.youtube.com/@fortworthdao",
    "https://www.instagram.com/fwtx_dao",
    "https://t.me/fwtxdao",
  ],
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "FWTX DAO",
  url: "https://fwtx.city",
  description: "Fort Worth Municipal DAO - Web3 civic innovation, digital sovereignty, and decentralized governance community in Fort Worth, Texas.",
};

const resolvedImageWithDomain = new URL(
  image || "/ogimage.png",
  Astro.site
).toString();

const makeTitle = title
  ? title + " | " + "FWTX DAO"
  : "FWTX DAO - Web3 Excellence of Fort Worth";

const metaDescription = description || "FWTX DAO is a Web3 and civic innovation community in Fort Worth, Texas. Join us for workshops, education, and building the decentralized future of North Texas.";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0A0F1C" />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <SEO
      title={makeTitle}
      description={metaDescription}
      canonical={canonicalURL}
      twitter={{
        creator: "@FWTX_DAO",
        site: "@FWTX_DAO",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: type,
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "FWTX DAO - Digital Sovereignty is Mission Critical",
          width: 1200,
          height: 630,
        },
      }}
    />

    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="FWTX DAO" />

    {type === "article" && publishDate && (
      <meta property="article:published_time" content={publishDate} />
    )}
    {type === "article" && author && (
      <meta property="article:author" content={author} />
    )}
    {type === "article" && tags && tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />

    <meta name="author" content="FWTX DAO" />
    <meta name="keywords" content="Fort Worth, DAO, Web3, blockchain, civic innovation, digital sovereignty, Texas, crypto, decentralization, community" />
    <link rel="canonical" href={canonicalURL} />

    <link rel="apple-touch-icon" sizes="180x180" href="/logo.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/logo.svg" />
  </head>
  <body class="bg-navy-950 min-h-screen text-gray-100 antialiased pt-20">
    <!-- Skip navigation -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:p-4 focus:bg-blue-500 focus:text-white focus:font-semibold">Skip to content</a>

    <!-- Flow field background -->
    <div class="fixed inset-0 z-0">
      <NeuralBackground
        client:load
        color="#3b82f6"
        bgColor="#0A0F1C"
        trailOpacity={0.12}
        particleCount={400}
        speed={0.6}
      />
    </div>

    <!-- Main content -->
    <div class="relative z-10" id="main-content">
      <Navbar />
      <slot />
      <Footer />
    </div>

    <style is:global>
      img {
        content-visibility: auto;
      }

      html {
        color-scheme: dark;
        scroll-behavior: smooth;
      }

      h1, h2, h3, h4, h5, h6 {
        text-wrap: balance;
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
        }
      }

      body {
        background-color: #0A0F1C;
      }

      ::selection {
        background-color: rgba(59, 130, 246, 0.3);
        color: #dbeafe;
      }

      ::-webkit-scrollbar {
        width: 8px;
      }

      ::-webkit-scrollbar-track {
        background: #0A0F1C;
      }

      ::-webkit-scrollbar-thumb {
        background: #3b82f6;
        border-radius: 4px;
      }

      ::-webkit-scrollbar-thumb:hover {
        background: #60a5fa;
      }

      /* Accent text */
      .accent-text {
        color: #60a5fa;
      }

      /* Glass card */
      .glass-card {
        background: rgba(15, 22, 41, 0.7);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(59, 130, 246, 0.1);
      }

      .glass-card:hover {
        border-color: rgba(59, 130, 246, 0.25);
        box-shadow: 0 0 30px rgba(59, 130, 246, 0.06);
      }

      /* Link styling */
      .cyber-link {
        position: relative;
        color: #94a3b8;
        transition: color 0.3s ease;
      }

      .cyber-link:hover {
        color: #60a5fa;
      }

      .cyber-link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 1px;
        background: #3b82f6;
        transition: width 0.3s ease;
      }

      .cyber-link:hover::after {
        width: 100%;
      }

      /* Prose dark mode for blog content */
      .prose-invert {
        --tw-prose-body: #cbd5e1;
        --tw-prose-headings: #f1f5f9;
        --tw-prose-lead: #94a3b8;
        --tw-prose-links: #60a5fa;
        --tw-prose-bold: #f1f5f9;
        --tw-prose-counters: #94a3b8;
        --tw-prose-bullets: #3b82f6;
        --tw-prose-hr: rgba(59, 130, 246, 0.2);
        --tw-prose-quotes: #e2e8f0;
        --tw-prose-quote-borders: #3b82f6;
        --tw-prose-captions: #94a3b8;
        --tw-prose-code: #60a5fa;
        --tw-prose-pre-code: #e2e8f0;
        --tw-prose-pre-bg: rgba(15, 22, 41, 0.8);
        --tw-prose-th-borders: rgba(59, 130, 246, 0.2);
        --tw-prose-td-borders: rgba(100, 116, 139, 0.3);
      }

      .font-display {
        font-family: 'Teko', sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.02em;
      }
    </style>
  </body>
</html>
