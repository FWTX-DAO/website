---
import Container from "@components/container.astro";
import { getFormattedDate } from "@utils/all";
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title}>
  <Container>
    <div class="mx-auto max-w-[735px] mt-14">
      <span class="text-frontier-amber uppercase tracking-wider text-sm font-medium">
        {frontmatter.category}
      </span>
      <h1
        class="font-display text-5xl lg:text-6xl font-bold tracking-tight mt-1 leading-tight text-white">
        {frontmatter.title}
      </h1>
      <div class="flex gap-2 mt-3 items-center flex-wrap md:flex-nowrap">
        <span class="text-slate-400">
          {frontmatter.author}
        </span>
        <span class="text-slate-400">&bull;</span>
        <time class="text-slate-400" datetime={frontmatter.publishDate}>
          {getFormattedDate(frontmatter.publishDate)}
        </time>
        <span class="text-slate-400 hidden md:block">&bull;</span>
        <div class="w-full md:w-auto flex flex-wrap gap-3">
          {
            frontmatter.tags.map((tag) => (
              <span class="text-sm text-slate-400">#{tag}</span>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mx-auto prose prose-lg prose-invert mt-6">
      <slot />
    </div>
    <div class="text-center mt-8">
      <a
        href="/blog"
        class="bg-transparent text-frontier-amber font-semibold border-2 border-frontier-amber/50 hover:border-frontier-amber hover:bg-frontier-amber/10 hover:shadow-glow-amber px-5 py-3 rounded-md transition-all duration-300 focus-visible:ring-2 focus-visible:ring-frontier-amber/50 focus-visible:ring-offset-2 focus-visible:ring-offset-cyber-dark inline-block"
        >&larr; Back to Blog</a
      >
    </div>
  </Container>
</Layout>
