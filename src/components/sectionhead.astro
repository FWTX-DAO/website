---
const { align = "center", as: Tag = "h2" } = Astro.props;
---

<div class:list={["mt-16", align === "center" && "text-center"]}>
  <Tag class="text-4xl lg:text-5xl font-bold lg:tracking-tight text-white">
    <span class="gradient-text"><slot name="title">Title</slot></span>
  </Tag>
  <p class="text-lg mt-4 text-slate-400 max-w-2xl mx-auto">
    <slot name="desc">Some description goes here</slot>
  </p>
</div>
