---
const { align = "center", as: Tag = "h2" } = Astro.props;
---

<div class:list={["mt-16", align === "center" && "text-center"]}>
  <Tag class="font-display text-5xl lg:text-6xl font-bold tracking-tight text-white">
    <slot name="title">Title</slot>
  </Tag>
  <p class="text-lg mt-4 text-slate-300 max-w-2xl mx-auto">
    <slot name="desc">Some description goes here</slot>
  </p>
</div>
