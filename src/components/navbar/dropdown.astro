---
import { Dropdown as DropdownContainer, DropdownItems } from "astro-navbar";
const { title, lastItem, children } = Astro.props;
const isExternal = (path) => path?.startsWith("http");
---

<li class="relative">
  <DropdownContainer class="group">
    <button
      class="flex items-center gap-1 w-full lg:w-auto lg:px-3 py-2 text-slate-300 hover:text-blue-400 transition-colors duration-300 min-h-[44px]"
      aria-label={`${title} menu`}>
      <span>{title}</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="3"
        stroke="currentColor"
        class="w-3 h-3 mt-0.5 group-open:rotate-180 transition-transform duration-300"
        aria-hidden="true">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
      </svg>
    </button>
    <DropdownItems>
      <div
        class:list={[
          "lg:absolute w-full lg:w-60 z-10",
          lastItem
            ? "lg:right-0 origin-top-right"
            : "lg:left-0 origin-top-left",
        ]}>
        <div
          class="px-3 lg:py-3 lg:bg-navy-900/95 lg:backdrop-blur-xl lg:rounded-lg lg:shadow-lg lg:border lg:border-blue-500/20 flex flex-col gap-1">
          {
            children.map((item) =>
              item.children ? (
                <div class="relative group/submenu">
                  <button
                    type="button"
                    class="py-2 px-2 text-slate-300 hover:text-blue-400 hover:bg-blue-500/5 rounded transition duration-300 min-h-[44px] flex items-center justify-between gap-3 w-full text-left"
                    aria-label={`${item.title} resources`}>
                    <span>{item.title}</span>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="3"
                      stroke="currentColor"
                      class="w-3 h-3 transition-transform duration-300 lg:-rotate-90 lg:group-hover/submenu:translate-x-0.5"
                      aria-hidden="true">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
                    </svg>
                  </button>
                  <div class="pl-3 ml-2 border-l border-navy-700/70 flex flex-col gap-1 lg:hidden">
                    {item.children.map((child) => (
                      <a
                        href={child.path}
                        target={isExternal(child.path) ? "_blank" : undefined}
                        rel={isExternal(child.path) ? "noopener noreferrer" : undefined}
                        class="py-2 px-2 text-sm text-slate-400 hover:text-blue-400 hover:bg-blue-500/5 rounded transition duration-300 min-h-[40px] flex items-center">
                        {child.title}
                      </a>
                    ))}
                  </div>
                  <div class="hidden lg:group-hover/submenu:flex lg:group-focus-within/submenu:flex lg:absolute lg:left-full lg:top-0 lg:min-w-56 lg:pl-2">
                    <div class="w-full rounded-lg border border-blue-500/20 bg-navy-900/95 p-2 shadow-lg backdrop-blur-xl flex flex-col gap-1">
                      {item.children.map((child) => (
                        <a
                          href={child.path}
                          target={isExternal(child.path) ? "_blank" : undefined}
                          rel={isExternal(child.path) ? "noopener noreferrer" : undefined}
                          class="py-2 px-2 text-slate-300 hover:text-blue-400 hover:bg-blue-500/5 rounded transition duration-300 min-h-[40px] flex items-center whitespace-nowrap">
                          {child.title}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              ) : (
                <a
                  href={item.path}
                  target={isExternal(item.path) ? "_blank" : undefined}
                  rel={isExternal(item.path) ? "noopener noreferrer" : undefined}
                  class="py-2 px-2 text-slate-300 hover:text-blue-400 hover:bg-blue-500/5 rounded transition duration-300 min-h-[44px] flex items-center">
                  {item.title}
                </a>
              )
            )
          }
        </div>
      </div>
    </DropdownItems>
  </DropdownContainer>
</li>
