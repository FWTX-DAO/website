---
import Link from "./ui/link.astro";
---

<div
  class="relative overflow-hidden bg-navy-900/80 backdrop-blur-xl p-8 md:px-20 md:py-20 mt-20 mx-auto max-w-5xl rounded-lg flex flex-col items-center text-center border border-blue-500/15 hover:border-blue-500/30 transition duration-500 group">

  <div class="absolute inset-0 bg-blue-500/3 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

  <!-- Corner accents -->
  <div class="absolute top-0 left-0 w-16 h-16 border-l-2 border-t-2 border-blue-500/20 rounded-tl-lg"></div>
  <div class="absolute top-0 right-0 w-16 h-16 border-r-2 border-t-2 border-blue-500/20 rounded-tr-lg"></div>
  <div class="absolute bottom-0 left-0 w-16 h-16 border-l-2 border-b-2 border-blue-500/20 rounded-bl-lg"></div>
  <div class="absolute bottom-0 right-0 w-16 h-16 border-r-2 border-b-2 border-blue-500/20 rounded-br-lg"></div>

  <h2 class="relative font-display text-5xl md:text-7xl tracking-tight font-bold text-white">
    Build the Future.
  </h2>
  <p class="relative text-slate-300 mt-4 text-lg md:text-xl max-w-2xl">
    Drive and build the future of Fort Worth <span class="text-blue-400">Web3 excellence</span> with us.
  </p>
  <div class="relative flex mt-8">
    <Link href="https://constitution.fwtx.city" style="primary">View our Whitepaper</Link>
  </div>
</div>
