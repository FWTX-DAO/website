---
import { Picture } from "astro:assets";
import heroImage from "../assets/hero.svg";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<main
  class="grid lg:grid-cols-2 place-items-center pt-16 pb-8 md:pt-12 md:pb-24 gap-8 lg:gap-12">
  <div class="py-6 md:order-1">
    <div class="relative hidden md:block">
      <Picture
        src={heroImage}
        alt="FWTX DAO Process"
        widths={[500, 700, 900]}
        sizes="(max-width: 1000px) 200vw, 720px"
        loading="eager"
        format="avif"
        class="relative z-10 invert opacity-85"
      />
    </div>
    <!-- Mobile decorative element -->
    <div class="flex md:hidden justify-center">
      <div class="relative w-20 h-20">
        <div class="absolute inset-0 bg-blue-500/20 blur-xl rounded-full animate-glow-pulse"></div>
        <img src="/logo.svg" alt="" class="relative w-full h-full" aria-hidden="true" />
      </div>
    </div>
  </div>
  <div class="animate-fade-in">
    <h1
      class="font-display text-6xl sm:text-7xl lg:text-8xl xl:text-9xl font-bold tracking-tight text-white leading-[0.9]">
      Web3 Excellence
      <br />
      <span class="text-blue-400">of Fort Worth</span>
    </h1>
    <div class="text-lg mt-6 text-slate-300 max-w-xl space-y-4 leading-relaxed">
      <p>
        We are a municipal DAO dedicated to evangelizing
        <span class="text-blue-400 font-medium">digital sovereignty</span> and property rights
        for Fort Worth - educating on the intersection of blockchain, cryptography,
        and ownership.
      </p>
      <p>
        We focus on the nuance of digital ownership and emerging tech for our
        constituents by fostering
        <span class="text-blue-400 font-medium">open source ecosystems</span>, knowledge
        sharing, and assets in our civic innovation lab.
      </p>
      <p>
        We aim to create a more technologically literate, informed, and
        equitable digital future for an efficient and optimized city.
        <a
          href="https://constitution.fwtx.city"
          class="text-blue-400 hover:text-blue-300 transition-colors duration-300 underline decoration-blue-500/30 hover:decoration-blue-400 underline-offset-4">
          Read our constitution and whitepaper.
        </a>
      </p>
    </div>
    <div class="mt-8 flex flex-col sm:flex-row gap-4">
      <Link
        href="https://dao.fwtx.city"
        target="_blank"
        style="primary"
        class="flex gap-2 items-center justify-center group"
        rel="noopener">
        <Icon class="w-5 h-5 group-hover:animate-pulse" name="bx:bx-user-plus" aria-hidden="true" />
        Join DAO
      </Link>
      <Link
        href="https://t.me/fwtxdao"
        target="_blank"
        style="primary"
        class="flex gap-2 items-center justify-center group"
        rel="noopener">
        <Icon class="w-5 h-5" name="bx:bxl-telegram" aria-hidden="true" />
        Telegram
      </Link>
      <Link
        size="lg"
        style="outline"
        rel="noopener"
        href="https://github.com/FWTX-DAO"
        class="flex gap-2 items-center justify-center group"
        target="_blank">
        <Icon class="text-blue-400 w-4 h-4" name="bx:bxl-github" aria-hidden="true" />
        GitHub
      </Link>
    </div>

    <!-- Status indicator -->
    <div class="mt-8 flex items-center gap-3">
      <div class="relative flex h-3 w-3">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-3 w-3 bg-green-400"></span>
      </div>
      <span class="text-sm text-slate-400 font-mono">DAO Status: <span class="text-green-400">Active</span></span>
    </div>
  </div>
</main>
