---
interface Props {
  size?: "md" | "lg";
  block?: boolean;
  style?: "outline" | "primary" | "muted";
  class?: string;
  [x: string]: any;
}

const {
  size = "md",
  style = "primary",
  block,
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  md: "px-5 py-2.5",
  lg: "px-6 py-3",
};

const styles = {
  outline: "bg-transparent text-blue-400 font-semibold border-2 border-blue-500/50 hover:border-blue-400 hover:bg-blue-500/10 hover:shadow-glow-sm transition-all duration-300",
  primary: "bg-blue-600 text-white font-semibold border-2 border-blue-600 hover:bg-blue-500 hover:border-blue-500 hover:shadow-glow-blue transition-all duration-300",
  muted: "bg-navy-800/60 hover:bg-navy-700 text-slate-300 border-2 border-transparent transition-all duration-300",
};
---

<button
  {...rest}
  class:list={[
    "rounded text-center transition focus-visible:ring-2 ring-offset-2 ring-blue-500/50 focus-visible:ring-offset-navy-950",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}
  ><slot />
</button>
